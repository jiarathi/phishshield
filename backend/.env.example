# --- Deployment ---
ENVIRONMENT=dev
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Scoring ---
SCAM_THRESHOLD=0.65

# --- Safety limits ---
MAX_TEXT_LENGTH=5000
MAX_URLS_PER_MESSAGE=10
RATE_LIMIT_PER_MINUTE=60

# --- Optional outbound reputation lookups (disabled by default) ---
ENABLE_REPUTATION_LOOKUPS=false
GOOGLE_SAFE_BROWSING_API_KEY=
VIRUSTOTAL_API_KEY=

# --- Network ---
HTTP_TIMEOUT_SECONDS=4.0
